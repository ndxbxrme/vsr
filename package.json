{
  "name": "vitalspace-remake",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --parallel --filter @vitalspace/api --filter @vitalspace/web --filter @vitalspace/worker dev",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @vitalspace/db db:generate",
    "db:migrate": "pnpm --filter @vitalspace/db db:migrate",
    "db:studio": "pnpm --filter @vitalspace/db db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  }
}
